+
+from tensorflow.keras.callbacks import ModelCheckpoint, ReduceLROnPlateau, EarlyStopping
+import datetime
+from tensorflow.keras.callbacks import TensorBoard
+
+
+log_dir = "logs/fit/" + datetime.datetime.now().strftime("%Y%m%d-%H%M")
+
+#
+tensorboard_callback = TensorBoard(log_dir=log_dir, histogram_freq=0)
+
+
+
+
+model_checkpoint = ModelCheckpoint(
+    filepath='Model/best_model'+datetime.datetime.now().strftime("%Y%m%d-%H%M")+'.h5',
+    monitor='val_loss',
+    save_best_only=True,
+    verbose=1
+)
+
+# EarlyStopping halts training when validation loss stops improving
+early_stopping = EarlyStopping(
+    monitor='val_loss',
+    patience=5,
+    restore_best_weights=True,
+    verbose=1
+)
+
+callbacks_list = [model_checkpoint, early_stopping, tensorboard_callback]
+
+data_augmentation = Sequential([
+    RandomFlip("horizontal"),
+    RandomRotation(0.1),
+    RandomZoom(0.1),
+], name="data_augmentation")
+
+
+def generateModel(inputShape):
+    inputs = tf.keras.Input(shape=inputShape)
+
+    x = data_augmentation(inputs)
+
+    # 1. Block (Fängt mit 32 Filtern an)
+    x = tf.keras.layers.Conv2D(filters=32, kernel_size=(3, 3), padding='same', activation='relu')(x)
+    x = tf.keras.layers.MaxPooling2D(pool_size=(2, 2), strides=2)(x)
+
+    # 2. Block (Verdoppelt auf 64 Filter)
+    x = tf.keras.layers.Conv2D(filters=64, kernel_size=(3, 3), padding='same', activation='relu')(x)
+    x = tf.keras.layers.MaxPooling2D(pool_size=(2, 2), strides=2)(x)
+
+    # 3. Block (Verdoppelt auf 128 Filter)
+    x = tf.keras.layers.Conv2D(filters=128, kernel_size=(3, 3), padding='same', activation='relu')(x)
+    x = tf.keras.layers.MaxPooling2D(pool_size=(2, 2), strides=2)(x)
+
+    # 4. Block (Verdoppelt auf 256 Filter - hier "versteht" das Netz das Bild)
+    x = tf.keras.layers.Conv2D(filters=256, kernel_size=(3, 3), padding='same', activation='relu')(x)
+    x = tf.keras.layers.MaxPooling2D(pool_size=(2, 2), strides=2)(x)
+
+    # Classifier-Kopf
+    x = tf.keras.layers.Flatten()(x)
+    x = tf.keras.layers.Dense(units=256, activation='relu')(x)
+    x = tf.keras.layers.Dropout(0.5)(x)  # Hier ist der richtige Ort für Dropout!
+
+    # Finale Schicht (MUSS bei Mixed Precision explizit float32 sein)
+    outputs = tf.keras.layers.Dense(units=train_df_filtered['labels'].nunique(), activation='softmax', dtype='float32')(
+        x)
+
+    model = tf.keras.Model(inputs=inputs, outputs=outputs)
+    return model
+
