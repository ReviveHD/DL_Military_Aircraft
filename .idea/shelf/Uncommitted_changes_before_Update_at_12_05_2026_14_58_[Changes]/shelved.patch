+import os
+
+
+import pandas as pd
+from sklearn.model_selection import train_test_split
+
+import tensorflow as tf
+
+
+def define_paths(dir):
+    filepaths = []
+    labels = []
+    folds = os.listdir(dir)
+    for fold in folds:
+        folderpath = os.path.join(dir, fold)
+        filelist = os.listdir(folderpath)
+        for file in filelist:
+            fpath = os.path.join(folderpath, file)
+            filepaths.append(fpath)
+            labels.append(fold)
+    return filepaths, labels
+
+def define_df(files, classes):
+    Fseries = pd.Series(files, name='filepaths')
+    Lseries = pd.Series(classes, name='labels')
+    return pd.concat([Fseries, Lseries], axis=1)
+
+def full_data(data_dir):
+    files, classes = define_paths(data_dir)
+    df = define_df(files, classes)
+    strat = df['labels']
+    # Split into 70% train and 30% temporary
+    train_df, dummy_df = train_test_split(df, train_size=0.7, shuffle=True, random_state=123, stratify=strat)
+    # Split the temporary 30% into 15% validation and 15% test
+    strat = dummy_df['labels']
+    valid_df, test_df = train_test_split(dummy_df, train_size=0.5, shuffle=True, random_state=123, stratify=strat)
+    return train_df, valid_df, test_df
